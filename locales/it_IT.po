msgid "Responsivas"
msgstr "Documenti di responsabilità"

msgid "Responsivas requires PHP 8.2 or higher. Current version: %s"
msgstr ""
"Responsibility Documents richiede PHP 8.2 o superiore. Versione attuale: %s"

msgid ""
"Responsivas requires TCPDF, which must be available in the GLPI vendor "
"directory."
msgstr ""
"Responsibility Documents richiede TCPDF, che deve essere disponibile nella "
"directory vendor di GLPI."

msgid ""
"Could not create the Responsivas plugin files directory. Check permissions."
msgstr ""
"Impossibile creare la directory dei file del plugin. Controlla i permessi."

msgid "Responsibility Forms"
msgstr "Moduli di responsabilità"

msgid "Responsivas plugin uninstalled. Configuration deleted."
msgstr ""
"Plugin Documenti di responsabilità disinstallato. Configurazione eliminata."

msgid "User not found."
msgstr "Utente non trovato."

msgid "The user has no assigned equipment."
msgstr "L'utente non ha apparecchiature assegnate."

msgid "Could not retrieve the entity."
msgstr "Impossibile recuperare l'entità."

msgid "The phone type for loan agreements is not configured in the plugin."
msgstr ""
"Il tipo di telefono per i contratti di comodato non è configurato nel "
"plugin."

msgid "The user has no phones of the configured type assigned."
msgstr "L'utente non ha telefoni del tipo configurato assegnati."

msgid "You must configure Witness 1 and Witness 2 in the plugin settings."
msgstr ""
"Devi configurare il Testimone 1 e il Testimone 2 nelle impostazioni del "
"plugin."

msgid "One or both configured witnesses are invalid or inactive."
msgstr ""
"Uno o entrambi i testimoni configurati non sono validi o sono inattivi."

msgid "You must configure the legal representative in the plugin settings."
msgstr ""
"Devi configurare il rappresentante legale nelle impostazioni del plugin."

msgid "The legal representative is invalid or inactive."
msgstr "Il rappresentante legale non è valido o è inattivo."

msgid ""
"Phone \"%s\" has no purchase price. Add it in Management → Administrative "
"and financial information → Purchase price."
msgstr ""
"Il telefono \"%s\" non ha un prezzo di acquisto. Aggiungilo in Gestione → "
"Informazioni amministrative e finanziarie → Prezzo di acquisto."

